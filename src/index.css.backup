  background-color: transparent !important;
}

:root[data-theme="black"] .border-gray-300:hover {
  background-color: #2a2a2a !important;
  border-color: #525252 !important;
  color: #ffffff !important;
}

:root[data-theme="black"] .border-gray-600 {
  border-color: #404040 !important;
  color: #e5e5e5 !important;
  background-color: transparent !important;
}

:root[data-theme="black"] .border-gray-600:hover {
  background-color: #2a2a2a !important;
  border-color: #525252 !important;
  color: #ffffff !important;
}

:root[data-theme="black"] .bg-transparent {
  background-color: transparent !important;
  color: #e5e5e5 !important;
}

:root[data-theme="black"] .bg-transparent:hover {
  background-color: #2a2a2a !important;
  color: #ffffff !important;
}

:root[data-theme="black"] .bg-red-600 {
  background-color: #dc2626 !important;
  color: #ffffff !important;
  border-color: #dc2626 !important;
}

:root[data-theme="black"] .bg-red-600:hover {
  background-color: #b91c1c !important;
  border-color: #b91c1c !important;
}

:root[data-theme="black"] .bg-red-700 {
  background-color: #b91c1c !important;
  color: #ffffff !important;
  border-color: #b91c1c !important;
}

:root[data-theme="black"] .bg-red-700:hover {
  background-color: #991b1b !important;
  border-color: #991b1b !important;
}

:root[data-theme="black"] .bg-green-600 {
  background-color: #16a34a !important;
  color: #ffffff !important;
  border-color: #16a34a !important;
}

:root[data-theme="black"] .bg-green-600:hover {
