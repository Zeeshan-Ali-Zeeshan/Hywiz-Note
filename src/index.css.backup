  color: #ffffff !important;
}

:root[data-theme="dark"] .bg-gray-600:hover {
  background-color: #374151 !important;
}

:root[data-theme="dark"] .border-gray-600 {
  border-color: #4b5563 !important;
  color: #d1d5db !important;
  background-color: transparent !important;
}

:root[data-theme="dark"] .border-gray-600:hover {
  background-color: #374151 !important;
  border-color: #6b7280 !important;
}

/* Black theme comprehensive button support */
:root[data-theme="black"] button {
  transition: all 0.2s ease;
}

:root[data-theme="black"] .bg-blue-600 {
  background-color: #3b82f6 !important;
  color: #ffffff !important;
  border-color: #3b82f6 !important;
}

:root[data-theme="black"] .bg-blue-600:hover {
