  border-color: #15803d !important;
}

:root[data-theme="black"] .bg-green-700:hover {
  background-color: #166534 !important;
  border-color: #166534 !important;
}

/* Button focus states for all themes - removed blue outline */
:root[data-theme="light"] button:focus {
  outline: none !important;
  box-shadow: none !important;
}

:root[data-theme="dark"] button:focus {
  outline: none !important;
  box-shadow: none !important;
}

:root[data-theme="black"] button:focus {
  outline: none !important;
  box-shadow: none !important;
}

/* Button disabled states */
button:disabled {
  opacity: 0.5 !important;
  cursor: not-allowed !important;
}

/* Icon button enhancements */
:root[data-theme="black"] .icon-button {
  background-color: transparent !important;
  color: #e5e5e5 !important;
  border: none !important;
  padding: 0.5rem !important;
  border-radius: 0.375rem !important;
  transition: all 0.2s ease !important;
}

:root[data-theme="black"] .icon-button:hover {
  background-color: #2a2a2a !important;
  color: #ffffff !important;
}

:root[data-theme="black"] .icon-button:focus {
  outline: none !important;
  box-shadow: 0 0 0 2px #3b82f6 !important;
}

/* Toolbar button enhancements */
:root[data-theme="black"] .toolbar-button {
  background-color: transparent !important;
  color: #e5e5e5 !important;
  border: 1px solid transparent !important;
  padding: 0.375rem !important;
  border-radius: 0.25rem !important;
  transition: all 0.2s ease !important;
}

:root[data-theme="black"] .toolbar-button:hover {
  background-color: #2a2a2a !important;
  color: #ffffff !important;
  border-color: #404040 !important;
}

:root[data-theme="black"] .toolbar-button.active {
  background-color: #3b82f6 !important;
  color: #ffffff !important;
  border-color: #3b82f6 !important;
}
/* Simple Checklist Styles - Clean and minimal */
.ProseMirror ul.simple-checklist {
  list-style: none;
  padding: 0;
  margin: 0.5rem 0;
}

.ProseMirror .simple-checklist-item-wrapper {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  padding: 0.25rem 0;
  margin: 0;
  list-style: none;
}

.ProseMirror .simple-checklist-label {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  cursor: pointer;
  margin: 0;
  padding: 0;
  height: 1.5rem;
}

.ProseMirror .simple-checklist-checkbox {
  width: 1rem;
  height: 1rem;
  cursor: pointer;
  accent-color: #3b82f6;
  border-radius: 0.25rem;
}

.ProseMirror .simple-checklist-content {
  flex: 1;
  min-width: 0;
}

.ProseMirror .simple-checklist-content.checked-content {
  text-decoration: line-through;
  opacity: 0.6;
}

.ProseMirror .simple-checklist-content p {
  margin: 0;
}

/* Dark theme */
:root[data-theme="dark"] .ProseMirror .simple-checklist-checkbox {
  accent-color: #60a5fa;
}

/* Black theme */
:root[data-theme="black"] .ProseMirror .simple-checklist-checkbox {
  accent-color: #60a5fa;
}
